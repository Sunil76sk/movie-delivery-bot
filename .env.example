# Telegram API Credentials
API_ID=your_api_id
API_HASH=your_api_hash
BOT_TOKEN=your_bot_token

# MongoDB
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/movie_delivery_bot?retryWrites=true&w=majority

# Channel IDs
STORAGE_CHANNEL_ID=-1001234567890
BACKUP_CHANNEL_ID=-1001234567891
MAIN_CHANNEL_ID=-1001234567892
BACKUP_JOIN_CHANNEL_ID=-1001234567893

# Admin IDs (comma separated)
ADMIN_IDS=123456789,987654321

# URL Shortener (optional)
SHORTENER_API_KEY=your_api_key
SHORTENER_API_URL=https://shortener-api.com/api
